# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# All values are optional for the app shell to run; providers/alerts read them as they come online.

# ── News ─────────────────────────────────────────────
IMD_NEWS_API_KEY=

# ── Universe / scoring (override defaults) ───────────
IMD_UNIVERSE=NIFTY50          # NIFTY50 | NIFTY500 | custom csv path
# IMD_SIGNAL_THRESHOLD=70     # min swing score to trigger an alert (0-100)

# ── Telegram alerts ──────────────────────────────────
IMD_TELEGRAM__BOT_TOKEN=
IMD_TELEGRAM__CHAT_ID=

# ── Email (SMTP) alerts ──────────────────────────────
IMD_EMAIL__SMTP_HOST=smtp.gmail.com
IMD_EMAIL__SMTP_PORT=587
IMD_EMAIL__USERNAME=
IMD_EMAIL__PASSWORD=          # use an app-password, not your real password
IMD_EMAIL__FROM_ADDR=
IMD_EMAIL__TO_ADDR=
